---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import completion from '../data/completion.json';
import skills from '../data/skills.json';

type Row = { date: string; forge: boolean; encode: boolean };

const PROGRAM_START = '2026-04-09'; // First public post — "Hello, Forge" / "Hello, Encode"

const todayISO = new Date().toISOString().slice(0, 10);
const completedRows = (completion as Row[]).filter((r) => r.date <= todayISO);
const daysSinceStart = Math.floor(
  (Date.parse(todayISO) - Date.parse(PROGRAM_START)) / 86_400_000
) + 1;
const totalLogged = completedRows.length;
const bothDays = completedRows.filter((r) => r.forge && r.encode).length;
const forgeDays = completedRows.filter((r) => r.forge).length;
const encodeDays = completedRows.filter((r) => r.encode).length;

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const latestForge = posts.filter((p) => p.data.category === 'forge').slice(0, 3);
const latestEncode = posts.filter((p) => p.data.category === 'encode').slice(0, 3);
const totalShipped = posts.length;

// Top tags across all posts (a coarse signal of what I'm spending time on).
const tagCounts = new Map<string, number>();
for (const p of posts) {
  for (const t of p.data.tags ?? []) {
    if (t === 'forge' || t === 'encode' || t === 'building-in-public') continue;
    tagCounts.set(t, (tagCounts.get(t) ?? 0) + 1);
  }
}
const topTags = [...tagCounts.entries()]
  .sort((a, b) => b[1] - a[1])
  .slice(0, 8)
  .map(([t, n]) => ({ t, n }));

const lastUpdated = todayISO;

// Skills — synced from .forge/metaskills + the forge-learning pillar table.
type Pillar = { id: string; name: string; level: number | 'GRADUATED'; lastSession: string; arc: string };
type Metaskill = { id: string; slug: string; title: string; status: string; oneSentence: string };
const metaskills = skills.metaskills as Metaskill[];
const allPillars = skills.pillars as Pillar[];
const lvl = (p: Pillar) => (p.level === 'GRADUATED' ? 6 : p.level);
const provenPillars = allPillars.filter((p) => lvl(p) >= 3).sort((a, b) => lvl(b) - lvl(a));
const developingCount = allPillars.filter((p) => lvl(p) >= 1 && lvl(p) < 3).length;
---

<Layout title="Resume" description="Living resume — what I'm building, what I'm learning, and what the work suggests about the builder.">
  <header class="mb-10">
    <p class="text-xs font-mono uppercase tracking-[0.25em] text-neutral-500 mb-3">// Living resume + cover letter</p>
    <h1 class="text-5xl font-bold tracking-tight mb-3">Miles</h1>
    <p class="text-lg text-neutral-300 max-w-2xl leading-relaxed">
      Running a 24-month public build program. Two pillars, every day:
      <span class="text-white">Forge</span> ships code, <span class="text-white">Encode</span> locks the lessons. The site you're on is the audit.
    </p>
    <p class="mt-4 text-xs font-mono text-neutral-500">
      Updated automatically · Last sync {lastUpdated}
    </p>
  </header>

  <!-- Cover letter — the prose. -->
  <section class="mb-14">
    <p class="text-xs font-mono uppercase tracking-[0.25em] text-neutral-500 mb-4">// 01 — Cover letter</p>
    <div class="space-y-5 text-neutral-200 leading-relaxed">
      <p>
        I build software, and I write down what the building taught me. Not as a daily journal — as a forensic record. Each Forge session ships something real and earns the right to a principle. Each Encode session sits down at zero with a concept and tries to leave with one thing locked. A day only counts when both pillars are done. The calendar on the home page is the audit; if you want to know whether I've been honest with the rule, scroll back through April.
      </p>
      <p>
        The thing I'm building right now is <span class="text-white">Workhorse</span> — a personal agent and vault that I use every day. It's the first of twelve products in the program. The point of building in front of people is that I can't quietly walk away from a bad design decision. Every trade-off lands in a post within a day. The post explains the mechanism, names the rule the mechanism enforces, and earns the rule via the artifact that prompted it. The freight-train air-brake post is a representative example: a sixty-second timeout was declared, threaded, and never connected to the wire. The fix was four lines. The principle was a type signature that makes the missing connection a compile error.
      </p>
      <p>
        I'll work on anything if you reach out — full-time, short engagement, contract, audit, applied AI in production, tooling that closes the gap between a prompt and a shipped artifact, post-incident or post-launch writing that turns a near-miss into a rule the organization can carry forward. If you read three posts and a pattern shows up that you want on a problem of yours, the email at the bottom of this page is the right way in.
      </p>
    </div>
  </section>

  <!-- Right now — the live data. -->
  <section class="mb-14">
    <p class="text-xs font-mono uppercase tracking-[0.25em] text-neutral-500 mb-4">// 02 — Right now</p>
    <dl class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
      <div class="border border-neutral-800 p-4">
        <dt class="text-[10px] font-mono uppercase tracking-wider text-neutral-500 mb-1">Day</dt>
        <dd class="text-2xl font-bold tracking-tight text-white">{daysSinceStart}<span class="text-neutral-600 text-base font-normal"> / 730</span></dd>
      </div>
      <div class="border border-neutral-800 p-4">
        <dt class="text-[10px] font-mono uppercase tracking-wider text-neutral-500 mb-1">Both pillars</dt>
        <dd class="text-2xl font-bold tracking-tight text-white">{bothDays}<span class="text-neutral-600 text-base font-normal"> / {totalLogged}</span></dd>
      </div>
      <div class="border border-neutral-800 p-4">
        <dt class="text-[10px] font-mono uppercase tracking-wider text-neutral-500 mb-1">Forge ships</dt>
        <dd class="text-2xl font-bold tracking-tight text-white">{forgeDays}</dd>
      </div>
      <div class="border border-neutral-800 p-4">
        <dt class="text-[10px] font-mono uppercase tracking-wider text-neutral-500 mb-1">Encode locks</dt>
        <dd class="text-2xl font-bold tracking-tight text-white">{encodeDays}</dd>
      </div>
    </dl>
    <p class="text-neutral-300 leading-relaxed">
      Active build: <span class="text-white font-semibold">Workhorse</span> — personal agent + vault, used daily. Build 1 of 12. The pipeline (audit chain, type-checked side channels, three-rounds-then-stop) is being designed by being used.
    </p>
  </section>

  <!-- Building — latest Forge. -->
  <section class="mb-14">
    <p class="text-xs font-mono uppercase tracking-[0.25em] text-neutral-500 mb-4">// 03 — Building (latest from Forge)</p>
    <div class="space-y-5">
      {latestForge.map((post) => (
        <article class="border-b border-neutral-800 pb-5 last:border-b-0">
          <p class="text-xs font-mono uppercase tracking-wider text-neutral-500 mb-2">
            {post.data.date.toISOString().slice(0, 10)}
          </p>
          <h3 class="text-xl font-bold mb-1 tracking-tight leading-snug">
            <a href={`/blog/${post.slug}`} class="no-underline text-white hover:underline">{post.data.title}</a>
          </h3>
          <p class="text-neutral-400 text-sm leading-relaxed">{post.data.excerpt}</p>
        </article>
      ))}
    </div>
  </section>

  <!-- Learning — latest Encode. -->
  <section class="mb-14">
    <p class="text-xs font-mono uppercase tracking-[0.25em] text-neutral-500 mb-4">// 04 — Learning (latest from Encode)</p>
    <div class="space-y-5">
      {latestEncode.map((post) => (
        <article class="border-b border-neutral-800 pb-5 last:border-b-0">
          <p class="text-xs font-mono uppercase tracking-wider text-neutral-500 mb-2">
            {post.data.date.toISOString().slice(0, 10)}
          </p>
          <h3 class="text-xl font-bold mb-1 tracking-tight leading-snug">
            <a href={`/blog/${post.slug}`} class="no-underline text-white hover:underline">{post.data.title}</a>
          </h3>
          <p class="text-neutral-400 text-sm leading-relaxed">{post.data.excerpt}</p>
        </article>
      ))}
    </div>
    {topTags.length > 0 && (
      <div class="mt-6">
        <p class="text-[10px] font-mono uppercase tracking-wider text-neutral-500 mb-3">Recurring threads</p>
        <ul class="flex flex-wrap gap-2">
          {topTags.map(({ t, n }) => (
            <li class="text-xs font-mono text-neutral-300 border border-neutral-800 px-2 py-1">
              {t} <span class="text-neutral-600">×{n}</span>
            </li>
          ))}
        </ul>
      </div>
    )}
  </section>

  <!-- Inferred — Claude-eye-view, evidence-based. -->
  <section class="mb-14">
    <p class="text-xs font-mono uppercase tracking-[0.25em] text-neutral-500 mb-4">// 05 — What the work suggests</p>
    <p class="text-sm text-neutral-500 mb-6 italic">
      Observations a model can make from {totalShipped} posts and {totalLogged} logged days. Claims linked to evidence; revised as the corpus grows.
    </p>
    <div class="space-y-6">
      <div class="border-l-2 border-neutral-700 pl-5">
        <h3 class="text-base font-bold text-white mb-1">Treats the pipeline as the product.</h3>
        <p class="text-neutral-400 text-sm leading-relaxed">
          Audit chain, prompt-revision phases, "forge Temper" — the artifacts ship, but the more interesting commits are the rules that govern how the artifacts ship. See <a class="text-neutral-200 underline decoration-neutral-700 hover:decoration-white" href="/blog/forge-s10-three-rounds-of-audit">the audit-chain post</a>: caps audit at three rounds because the cost-of-finding curve flattens.
        </p>
      </div>
      <div class="border-l-2 border-neutral-700 pl-5">
        <h3 class="text-base font-bold text-white mb-1">Reaches for industrial-history analogies to teach engineering principles.</h3>
        <p class="text-neutral-400 text-sm leading-relaxed">
          Freight-train air brakes for the AbortSignal that wasn't connected. Therac-25 for the UI flag that wasn't tied to hardware state. Railway interlocking for state machines. The analogy isn't decorative — it picks the failure mode out of the noise.
        </p>
      </div>
      <div class="border-l-2 border-neutral-700 pl-5">
        <h3 class="text-base font-bold text-white mb-1">Names the principle, then earns it via the artifact.</h3>
        <p class="text-neutral-400 text-sm leading-relaxed">
          Posts open with the concrete failure, name the mechanism, then generalize. The generalization is held to the bar of the artifact that prompted it; nothing gets named until something concrete forced the name.
        </p>
      </div>
      <div class="border-l-2 border-neutral-700 pl-5">
        <h3 class="text-base font-bold text-white mb-1">Type signatures over conventions.</h3>
        <p class="text-neutral-400 text-sm leading-relaxed">
          When a wrapper had to be remembered to be used, the fix was a signature change that makes forgetting a compile error. Comments aren't trusted to enforce invariants; the type system is.
        </p>
      </div>
      <div class="border-l-2 border-neutral-700 pl-5">
        <h3 class="text-base font-bold text-white mb-1">Sizes effort to artifact, not to tooling.</h3>
        <p class="text-neutral-400 text-sm leading-relaxed">
          A vault writer touching twenty-four years of personal data gets the full audit chain. A record button on a dashboard gets three rounds, then ships. The same person who designed the audit decides when to stop using it.
        </p>
      </div>
      <div class="border-l-2 border-neutral-700 pl-5">
        <h3 class="text-base font-bold text-white mb-1">Calibrates from misses, not just hits.</h3>
        <p class="text-neutral-400 text-sm leading-relaxed">
          Days where only one pillar lands are visible on the calendar by design. The misses are the data; flattening them would defeat the audit.
        </p>
      </div>
    </div>
  </section>

  <!-- Skills — machine-tracked from the build system; earned, not asserted. -->
  <section class="mb-14">
    <p class="text-xs font-mono uppercase tracking-[0.25em] text-neutral-500 mb-4">// 06 — Skills (tracked, not asserted)</p>
    <p class="text-sm text-neutral-500 mb-6 italic">
      Auto-synced from the build system — not a self-reported list. Metaskills are disciplines the pipeline enforces on every session; pillars are capability levels on a 0–5 scale (3 = writes independently, 4 = debugs under pressure, 5 = teaches). New entries appear the moment the work earns them.
    </p>
    {metaskills.length > 0 && (
      <div class="mb-8">
        <p class="text-[10px] font-mono uppercase tracking-wider text-neutral-500 mb-3">Metaskills · {metaskills.length} codified</p>
        <div class="space-y-5">
          {metaskills.map((m) => (
            <div class="border-l-2 border-neutral-700 pl-5">
              <h3 class="text-base font-bold text-white mb-1">
                {m.title}
                {m.status && <span class="ml-2 align-middle text-[10px] font-mono uppercase tracking-wider text-neutral-600">{m.status}</span>}
              </h3>
              <p class="text-neutral-400 text-sm leading-relaxed">{m.oneSentence}</p>
            </div>
          ))}
        </div>
      </div>
    )}
    {provenPillars.length > 0 && (
      <div>
        <p class="text-[10px] font-mono uppercase tracking-wider text-neutral-500 mb-3">Capability pillars at working proficiency · level 3+</p>
        <ul class="space-y-3">
          {provenPillars.map((p) => (
            <li class="grid grid-cols-[1fr_auto] gap-4 items-baseline border-b border-neutral-800 pb-3 last:border-b-0">
              <div>
                <span class="text-white font-semibold">{p.name}</span>
                <span class="text-neutral-500 text-sm"> — {p.arc}</span>
              </div>
              <span class="text-xs font-mono text-neutral-400 whitespace-nowrap">{p.level === 'GRADUATED' ? 'GRADUATED' : `L${p.level} / 5`}</span>
            </li>
          ))}
        </ul>
        {developingCount > 0 && (
          <p class="mt-5 text-xs font-mono text-neutral-600">+ {developingCount} more pillars in development (level 1–2), tracked until they reach working proficiency.</p>
        )}
      </div>
    )}
  </section>

  <!-- Built independently — what's shipped solo with AI as the team. -->
  <section class="mb-14">
    <p class="text-xs font-mono uppercase tracking-[0.25em] text-neutral-500 mb-4">// 07 — Built independently (with AI as the team)</p>
    <p class="text-sm text-neutral-500 mb-6 italic">
      Things designed, built, and shipped solo — outside paid work, AI as the only collaborator. The list is conservative; if it's listed, the artifact runs and the source is in a repo you can read.
    </p>
    <div class="space-y-6">
      <div class="border-l-2 border-neutral-700 pl-5">
        <h3 class="text-base font-bold text-white mb-1">Workhorse — personal agent + vault</h3>
        <p class="text-neutral-400 text-sm leading-relaxed">
          Local-first daily-practice substrate. Browser-side voice recording, raw-stream upload to a Node API, OpenAI Whisper transcription, Anthropic extraction, append-only flat-markdown vault keyed by SHA-256 idempotency. TypeScript + Node 20 + React + Vite + shadcn. Build one of twelve in the Love Learn Lift program; runs daily on my own machine. Repo: <a class="text-neutral-200 underline decoration-neutral-700 hover:decoration-white" href="https://github.com/tortoisehq/workhorse" rel="noopener noreferrer">github.com/tortoisehq/workhorse</a>.
        </p>
      </div>
      <div class="border-l-2 border-neutral-700 pl-5">
        <h3 class="text-base font-bold text-white mb-1">Forge — the build pipeline that ships the program</h3>
        <p class="text-neutral-400 text-sm leading-relaxed">
          Eight-phase typed-token protocol: state-check → intake → ten-expert risk scan → prompt-build → dual-auditor (internal panel plus two external reviewers, every finding source-checked) → code review → ship → closeout. Designed by being used; fifteen-plus sessions of mid-protocol evolution captured in version-controlled phase files. The pipeline is itself one of the artifacts the program ships — the rule that governs how every other artifact ships. Reading list: any post on this site tagged <span class="font-mono text-neutral-300">pipeline</span>.
        </p>
      </div>
      <div class="border-l-2 border-neutral-700 pl-5">
        <h3 class="text-base font-bold text-white mb-1">Love Learn Lift — public-build site</h3>
        <p class="text-neutral-400 text-sm leading-relaxed">
          The site you're reading. Astro static build, dark-first design, daily-completion calendar that auto-syncs from the Forge + Encode session artifacts in two separate repos. The resume reads its own cadence numbers from the same data the calendar does — no manual editing. Designed so the audit-chain ships alongside the artifacts it audits.
        </p>
      </div>
    </div>
  </section>

  <!-- Milestones — dated shipped events; the artifacts in section 06 were built via these. -->
  <section class="mb-14">
    <p class="text-xs font-mono uppercase tracking-[0.25em] text-neutral-500 mb-4">// 08 — Milestones (dated shipped events)</p>
    <p class="text-sm text-neutral-500 mb-6 italic">
      Specific shipped events, most recent first. Every entry corresponds to a public commit in a tracked repo plus a blog post or session handoff documenting what shipped and why.
    </p>
    <ul class="space-y-4">
      <li class="grid grid-cols-[100px_1fr] gap-4">
        <span class="text-xs font-mono uppercase tracking-wider text-neutral-500 pt-1">2026-05-11</span>
        <div>
          <p class="text-white font-semibold">Forge pipeline v3.3 — discipline becomes hardware</p>
          <p class="text-neutral-400 text-sm leading-relaxed">Nineteen improvements + five operational decisions shipped in a single session. Source-check discipline promoted from voluntary metaskill to harness-enforced rule across the entire router. Two new phases added (context-catchup before any task work; task-classification judge between intake and the heavy phases). Sixteen of seventeen internal checks deprecated at zero hit rate. Pipeline-state external-audit machinery activated; the pipeline now audits itself across three independent LLMs every ten sessions.</p>
        </div>
      </li>
      <li class="grid grid-cols-[100px_1fr] gap-4">
        <span class="text-xs font-mono uppercase tracking-wider text-neutral-500 pt-1">2026-05-09</span>
        <div>
          <p class="text-white font-semibold">Twilio inbound voice webhook — first public-internet endpoint</p>
          <p class="text-neutral-400 text-sm leading-relaxed">HMAC signature validation + caller-ID whitelist + kill-switch + RecordingUrl allowlist (SSRF defense) + storage upload with idempotency + structured logging with PII redaction. First production endpoint accepting unsolicited internet traffic; triple-auditor cycle (Google + Anthropic + OpenAI cross-LLM) caught one P0 and four P1s pre-ship.</p>
        </div>
      </li>
      <li class="grid grid-cols-[100px_1fr] gap-4">
        <span class="text-xs font-mono uppercase tracking-wider text-neutral-500 pt-1">2026-05-06</span>
        <div>
          <p class="text-white font-semibold">Railway production wiring + smoke endpoint</p>
          <p class="text-neutral-400 text-sm leading-relaxed">First non-localhost deployment of the Workhorse API. Twelve-factor environment loading, dotenv-vs-process-env precedence resolved, public smoke endpoint, Vercel domain routing. The "is this thing on" milestone the pipeline used to talk about hypothetically.</p>
        </div>
      </li>
      <li class="grid grid-cols-[100px_1fr] gap-4">
        <span class="text-xs font-mono uppercase tracking-wider text-neutral-500 pt-1">2026-05-04</span>
        <div>
          <p class="text-white font-semibold">Right-Size the Protocol — first dispatch-level override</p>
          <p class="text-neutral-400 text-sm leading-relaxed">A pipeline that was running a sixteen-hour FULL HIGH dual-auditor cycle on a five-line vite-config fix got source-checked, abandoned mid-protocol, and the fix shipped direct in twenty-five minutes. The override became the canonical example for the right-sizing memory rule that later codified as the forge-judge metalayer at S20.</p>
        </div>
      </li>
      <li class="grid grid-cols-[100px_1fr] gap-4">
        <span class="text-xs font-mono uppercase tracking-wider text-neutral-500 pt-1">2026-04-30</span>
        <div>
          <p class="text-white font-semibold">First forge-improve cadence — thirteen pipeline IMPs</p>
          <p class="text-neutral-400 text-sm leading-relaxed">First scheduled meta-cycle. P0 / P1 distinction codified in REJECTED tokens, cross-frame heuristics added to the internal panel, mental-model hit-rate logging started, two "think like" expert frames seeded (external-auditor + Type-B runtime). The cadence that compounds every ten sessions started here.</p>
        </div>
      </li>
      <li class="grid grid-cols-[100px_1fr] gap-4">
        <span class="text-xs font-mono uppercase tracking-wider text-neutral-500 pt-1">2026-04-23</span>
        <div>
          <p class="text-white font-semibold">External-auditor protocol codified as load-bearing</p>
          <p class="text-neutral-400 text-sm leading-relaxed">Three rounds of external review against an independent LLM caught eleven of eleven P0s the internal panel missed. The audit chain stopped being a recommendation and became the gate; everything FULL HIGH-risk ships through it.</p>
        </div>
      </li>
      <li class="grid grid-cols-[100px_1fr] gap-4">
        <span class="text-xs font-mono uppercase tracking-wider text-neutral-500 pt-1">2026-04-17</span>
        <div>
          <p class="text-white font-semibold">Vault writer + SHA-256 idempotency keys</p>
          <p class="text-neutral-400 text-sm leading-relaxed">Append-only flat-markdown vault with frontmatter idempotency keys. The same input never writes twice; duplicate ingestion is structurally impossible. The substrate every later artifact stores against.</p>
        </div>
      </li>
      <li class="grid grid-cols-[100px_1fr] gap-4">
        <span class="text-xs font-mono uppercase tracking-wider text-neutral-500 pt-1">2026-04-15</span>
        <div>
          <p class="text-white font-semibold">Forge pipeline v1.0 — first full session through the protocol</p>
          <p class="text-neutral-400 text-sm leading-relaxed">First task shipped through the complete eight-phase typed-token pipeline. The shape worked; everything since has been iteration on the same skeleton.</p>
        </div>
      </li>
      <li class="grid grid-cols-[100px_1fr] gap-4">
        <span class="text-xs font-mono uppercase tracking-wider text-neutral-500 pt-1">2026-04-09</span>
        <div>
          <p class="text-white font-semibold">Program start — Love Learn Lift + Forge + Encode</p>
          <p class="text-neutral-400 text-sm leading-relaxed">First public post on tortoisehq.io. Calendar starts logging. The twenty-four-month commitment becomes a publicly auditable surface from day one.</p>
        </div>
      </li>
    </ul>
  </section>

  <!-- Trajectory — past + present. -->
  <section class="mb-14">
    <p class="text-xs font-mono uppercase tracking-[0.25em] text-neutral-500 mb-4">// 09 — Trajectory</p>
    <ul class="space-y-4">
      <li class="grid grid-cols-[100px_1fr] gap-4">
        <span class="text-xs font-mono uppercase tracking-wider text-neutral-500 pt-1">2026 — now</span>
        <div>
          <p class="text-white font-semibold">Love Learn Lift — 24-month public build program</p>
          <p class="text-neutral-400 text-sm leading-relaxed">Forge + Encode, both every day. Twelve products in twenty-four months. Workhorse is build one.</p>
        </div>
      </li>
      <li class="grid grid-cols-[100px_1fr] gap-4">
        <span class="text-xs font-mono uppercase tracking-wider text-neutral-500 pt-1">prior</span>
        <div>
          <p class="text-white font-semibold">Ironridge / NightOwl</p>
          <p class="text-neutral-400 text-sm leading-relaxed">Product work pre-dating Love Learn Lift. Sessions S33–S47 carried forward the pillar system that Love Learn Lift's pipeline now extends.</p>
        </div>
      </li>
    </ul>
  </section>

  <!-- Contact. -->
  <section class="mb-6">
    <p class="text-xs font-mono uppercase tracking-[0.25em] text-neutral-500 mb-4">// 10 — Contact</p>
    <ul class="space-y-2 text-neutral-300">
      <li><a class="text-white underline decoration-neutral-700 hover:decoration-white" href="mailto:lovelearnlift@gmail.com">lovelearnlift@gmail.com</a></li>
      <li><a class="text-white underline decoration-neutral-700 hover:decoration-white" href="https://github.com/tortoisehq" rel="noopener noreferrer">github.com/tortoisehq</a></li>
    </ul>
  </section>
</Layout>
