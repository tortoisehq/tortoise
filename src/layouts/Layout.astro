---
import '../styles/global.css';
import { categoryList } from '../lib/categories';

interface Props {
  title?: string;
  description?: string;
}

const { title = 'Tortoise', description = 'A 24-month public build program.' } = Astro.props;
const fullTitle = title === 'Tortoise' ? title : `${title} — Tortoise`;
const year = new Date().getFullYear();
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="alternate" type="application/rss+xml" title="Tortoise" href="/rss.xml" />
    <title>{fullTitle}</title>
  </head>
  <body class="min-h-screen flex flex-col">
    <header class="border-b border-neutral-800">
      <div class="max-w-3xl mx-auto px-6 py-5 flex items-center justify-between">
        <a href="/" class="text-lg font-semibold tracking-tight no-underline">Tortoise</a>
        <nav class="text-sm">
          <ul class="flex flex-wrap gap-x-4 gap-y-1">
            <li><a href="/">Home</a></li>
            {categoryList.map((c) => <li><a href={`/blog/${c.slug}`}>{c.name}</a></li>)}
            <li><a href="/rss.xml">RSS</a></li>
          </ul>
        </nav>
      </div>
    </header>

    <main class="flex-1 max-w-3xl w-full mx-auto px-6 py-12">
      <slot />
    </main>

    <footer class="border-t border-neutral-800 mt-16">
      <div class="max-w-3xl mx-auto px-6 py-6 text-sm text-neutral-400 flex items-center justify-between">
        <span>&copy; {year} Tortoise</span>
        <a href="https://github.com/" rel="noopener noreferrer">GitHub</a>
      </div>
    </footer>
  </body>
</html>
