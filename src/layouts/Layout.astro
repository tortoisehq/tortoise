---
import '../styles/global.css';
import { categoryList, categories, type CategorySlug } from '../lib/categories';

interface Props {
  title?: string;
  description?: string;
  /**
   * Color palette for this page. 'forge' = black, 'encode' = white,
   * undefined = the neutral default (dark gray) used for blog index, 404, etc.
   */
  palette?: CategorySlug;
  /** When set, emits BlogPosting JSON-LD + og:type=article for a single post. */
  article?: { date: string; category: string; tags: string[] };
}

const { title = 'Love Learn Lift', description = 'A 24-month public build program.', palette, article } = Astro.props;
const fullTitle = title === 'Love Learn Lift' ? title : `${title} — Love Learn Lift`;
const year = new Date().getFullYear();

// SEO / AI-discoverability: canonical URL + schema.org structured data.
const canonical = new URL(Astro.url.pathname, Astro.site).href;
const siteUrl = Astro.site?.href ?? 'https://lovelearnlift.com/';
const ogType = article ? 'article' : 'website';
const jsonLd = article
  ? {
      '@context': 'https://schema.org',
      '@type': 'BlogPosting',
      headline: title,
      description,
      datePublished: article.date,
      articleSection: article.category,
      keywords: article.tags.join(', '),
      url: canonical,
      mainEntityOfPage: canonical,
      isPartOf: { '@type': 'WebSite', name: 'Love Learn Lift', url: siteUrl },
      publisher: { '@type': 'Organization', name: 'Love Learn Lift', url: siteUrl },
    }
  : {
      '@context': 'https://schema.org',
      '@type': 'WebSite',
      name: 'Love Learn Lift',
      description,
      url: siteUrl,
    };

const p = palette ? categories[palette].palette : null;

// Resolve classes per palette. Default falls back to the legacy dark-neutral palette.
const rootBg = p ? p.bg : 'bg-neutral-950';
const rootText = p ? p.text : 'text-neutral-100';
const navText = p ? p.textMuted : 'text-neutral-400';
// S61 repaint: encode + forge are dark/flame (hover to white); dispatch + beacon are light (hover to black).
const navHover = p ? ((palette === 'encode' || palette === 'forge') ? 'hover:text-white' : 'hover:text-black') : 'hover:text-neutral-100';
const borderColor = p ? p.border : 'border-neutral-800';
const footerMuted = p ? p.textMuted : 'text-neutral-400';
---

<!doctype html>
<html lang="en" class={palette === 'dispatch' || palette === 'beacon' ? '' : 'dark'}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{fullTitle}</title>
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="alternate" type="application/rss+xml" title="Love Learn Lift — All posts" href="/rss.xml" />
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="Love Learn Lift" />
    <meta property="og:locale" content="en_US" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body class={`min-h-screen flex flex-col ${rootBg} ${rootText}`}>
    <header class={`border-b ${borderColor}`}>
      <div class="max-w-3xl mx-auto px-6 py-5 flex items-center justify-between">
        <a href="/" class="text-lg font-semibold tracking-tight no-underline">Love Learn Lift</a>
        <nav class={`text-sm ${navText}`}>
          <ul class="flex flex-wrap gap-x-5 gap-y-1">
            <li><a class={navHover} href="/">Home</a></li>
            {categoryList.map((c) => (
              <li><a class={navHover} href={`/${c.slug}`}>{c.name}</a></li>
            ))}
            <li><a class={navHover} href="/encode/learn">Learn</a></li>
            <li><a class={navHover} href="/encode/homework">Homework</a></li>
          </ul>
        </nav>
      </div>
    </header>

    <main class="flex-1 max-w-3xl w-full mx-auto px-6 py-12">
      <slot />
    </main>

    <footer class={`border-t ${borderColor} mt-16`}>
      <div class={`max-w-3xl mx-auto px-6 py-6 text-sm ${footerMuted} flex items-center justify-between`}>
        <span>&copy; {year} Love Learn Lift</span>
        <a class={navHover} href="https://github.com/tortoisehq" rel="noopener noreferrer">GitHub</a>
      </div>
    </footer>
  </body>
</html>
