---
import { getCollection } from 'astro:content';

interface Props {
  /** ISO date "YYYY-MM-DD" — defaults to today. Calendar shows through this month. */
  today?: string;
  /** ISO date "YYYY-MM-DD" — first month to render. Defaults to program start (April 2026). */
  start?: string;
}

const { today, start = '2026-04-01' } = Astro.props;

const todayDate = today ?? new Date().toISOString().slice(0, 10);
const [tY, tM] = todayDate.split('-').map(Number);
const [sY, sM] = start.split('-').map(Number);

// A day "counts" when at least one blog post shipped that day (any pillar).
// Derived straight from the published posts — no external pipeline, always current.
const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .map((p) => ({ date: p.data.date.toISOString().slice(0, 10), cat: p.data.category }))
  .filter((p) => p.date <= todayDate);

const postedDates = new Set(posts.map((p) => p.date));
const doneDays = postedDates.size;
const forgeCount = posts.filter((p) => p.cat === 'forge').length;
const encodeCount = posts.filter((p) => p.cat === 'encode').length;
const beaconCount = posts.filter((p) => p.cat === 'beacon').length;

const MONTH_NAMES = [
  'January', 'February', 'March', 'April', 'May', 'June',
  'July', 'August', 'September', 'October', 'November', 'December',
];

// Build the list of months from start month through current month, oldest first.
function monthsBetween(startY: number, startM: number, endY: number, endM: number) {
  const months: { year: number; month: number }[] = [];
  let y = startY, m = startM;
  while (y < endY || (y === endY && m <= endM)) {
    months.push({ year: y, month: m });
    m += 1;
    if (m > 12) { m = 1; y += 1; }
  }
  return months;
}

const monthsList = monthsBetween(sY, sM, tY, tM);

type Cell = { day: number | null; iso?: string; done?: boolean; isToday?: boolean; isFuture?: boolean };

function pad2(n: number) { return n < 10 ? `0${n}` : `${n}`; }

function buildMonth(year: number, month: number): Cell[] {
  const firstDayOfMonth = new Date(`${year}-${pad2(month)}-01T00:00:00`);
  const offset = firstDayOfMonth.getDay();
  const daysInMonth = new Date(year, month, 0).getDate();

  const cells: Cell[] = [];
  for (let i = 0; i < offset; i++) cells.push({ day: null });
  for (let d = 1; d <= daysInMonth; d++) {
    const iso = `${year}-${pad2(month)}-${pad2(d)}`;
    cells.push({
      day: d,
      iso,
      done: postedDates.has(iso),
      isToday: iso === todayDate,
      isFuture: iso > todayDate,
    });
  }
  while (cells.length % 7 !== 0) cells.push({ day: null });
  return cells;
}

const renderedMonths = monthsList.map(({ year, month }) => ({
  year,
  month,
  name: MONTH_NAMES[month - 1],
  cells: buildMonth(year, month),
  id: `cal-${year}-${pad2(month)}`,
  isCurrent: year === tY && month === tM,
}));

const DOW = ['S', 'M', 'T', 'W', 'T', 'F', 'S'];
const currentMonthId = `cal-${tY}-${pad2(tM)}`;
---

<section class="bg-neutral-900 border-y border-neutral-800">
  <div class="max-w-6xl mx-auto px-6 py-12 md:py-16">
    <div class="flex items-baseline justify-between mb-8 flex-wrap gap-3">
      <div>
        <p class="text-xs font-mono uppercase tracking-[0.25em] text-neutral-500 mb-2">// Daily Completion</p>
        <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-white">At least one, every day.</h2>
      </div>
      <div class="flex items-center gap-x-6 gap-y-2 text-sm font-mono text-neutral-400 flex-wrap">
        <span><span class="text-white font-semibold">{doneDays}</span> days shipped</span>
        <span class="text-neutral-600 hidden md:inline">|</span>
        <span><span class="text-white">F</span> {forgeCount} · <span class="text-white">E</span> {encodeCount} · <span class="text-white">B</span> {beaconCount}</span>
        <span class="text-neutral-600 hidden md:inline">|</span>
        <span class="flex items-center gap-2"><span class="inline-block w-3 h-3 bg-gold"></span> a post shipped</span>
      </div>
    </div>

    <!-- Horizontally scrollable track of months. Each month is a snap point. -->
    <div
      id="calendar-track"
      class="flex gap-8 overflow-x-auto snap-x snap-mandatory pb-4 -mx-6 px-6 scroll-smooth"
      style="scrollbar-width: thin; scrollbar-color: #404040 transparent;"
    >
      {renderedMonths.map((m) => (
        <div
          id={m.id}
          class={`snap-start shrink-0 w-[280px] md:w-[320px] ${m.isCurrent ? 'ring-1 ring-gold/40 rounded-md p-3 -m-3' : ''}`}
        >
          <div class="flex items-baseline justify-between mb-4">
            <h3 class="text-sm font-mono uppercase tracking-[0.25em] text-neutral-300">
              {m.name} <span class="text-neutral-600">{m.year}</span>
            </h3>
            {m.isCurrent && (
              <span class="text-[10px] font-mono uppercase tracking-wider text-gold">now</span>
            )}
          </div>
          <div class="grid grid-cols-7 gap-1.5">
            {DOW.map((d) => (
              <div class="text-[10px] font-mono uppercase tracking-wider text-neutral-600 text-center pb-1">{d}</div>
            ))}
            {m.cells.map((cell) => {
              if (cell.day === null) {
                return <div class="aspect-square"></div>;
              }
              return (
                <div class={`aspect-square relative ${cell.isToday ? 'ring-2 ring-gold' : ''}`}>
                  {cell.isFuture ? (
                    <div class="absolute inset-0 border border-neutral-800"></div>
                  ) : (
                    <div class={`absolute inset-0 ${cell.done ? 'bg-gold' : 'bg-neutral-800'}`}></div>
                  )}
                  <span class={`relative z-10 flex items-center justify-center w-full h-full text-[11px] font-mono ${
                    cell.done ? 'text-black font-semibold' : cell.isFuture ? 'text-neutral-600' : 'text-neutral-500'
                  }`}>{cell.day}</span>
                </div>
              );
            })}
          </div>
        </div>
      ))}
    </div>

    <p class="mt-3 text-[11px] font-mono uppercase tracking-wider text-neutral-600">
      ← scroll →
    </p>
  </div>
</section>

<script define:vars={{ currentMonthId }}>
  // Auto-scroll the current month into view on load.
  const track = document.getElementById('calendar-track');
  const current = document.getElementById(currentMonthId);
  if (track && current) {
    track.scrollLeft = current.offsetLeft - track.offsetLeft - 16;
  }
</script>
