---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import PostListItem from '../../components/PostListItem.astro';
import { categories } from '../../lib/categories';

const meta = categories.forge;

const posts = (await getCollection('blog', ({ data }) => !data.draft && data.category === 'forge'))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<Layout title={meta.name} description={meta.description} palette="forge">
  <header class="mb-12">
    <p class="text-xs font-mono uppercase tracking-[0.25em] text-neutral-500 mb-3">// Build pillar</p>
    <h1 class="text-5xl font-bold tracking-tight mb-3">Forge</h1>
    <p class="text-lg text-neutral-300 max-w-xl">Building and shipping. Sessions where code lands in production, the trade-offs that earned it, and the rules I write so I don't make the same mistake twice.</p>
  </header>

  {posts.length === 0 ? (
    <p class="text-neutral-400">No posts in this category yet.</p>
  ) : (
    <div>
      {posts.map((post) => <PostListItem post={post} palette="forge" />)}
    </div>
  )}
</Layout>
