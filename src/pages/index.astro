---
import '../styles/global.css';
import { getCollection } from 'astro:content';
import Calendar from '../components/Calendar.astro';
import { categoryList } from '../lib/categories';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => (b.data.date.getTime() - a.data.date.getTime()) || b.slug.localeCompare(a.slug, undefined, { numeric: true }));

// Forge has two builds (Build One = Workhorse, Build Two = Steward; absent `build`
// defaults to Workhorse). Show each build as its own labeled stack so they don't jumble.
const forgeAll = posts.filter((p) => p.data.category === 'forge');
const forgeBuilds = [
  { name: 'Workhorse', order: 'Build One', stage: 'Alpha Arc', href: '/forge/workhorse', posts: forgeAll.filter((p) => p.data.build !== 'steward').slice(0, 3) },
  { name: 'Steward', order: 'Build Two', stage: 'Alpha Arc', href: '/forge/steward', posts: forgeAll.filter((p) => p.data.build === 'steward').slice(0, 3) },
];
const encodePosts = posts.filter((p) => p.data.category === 'encode').slice(0, 4);
// Beacon archived from the homepage S61 (still lives at /beacon).
// Dispatch archived from the homepage E32 (still lives at /dispatch) — being spun into its own creative/design site.

const year = new Date().getFullYear();
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="A 24-month public build program. Forge: building and shipping. Encode: learning in public." />
    <title>Love Learn Lift</title>
  </head>
  <body class="min-h-screen bg-black text-white antialiased">
    <!-- Header — full-width black -->
    <header class="border-b border-neutral-800">
      <div class="max-w-6xl mx-auto px-6 py-5 flex items-center justify-between">
        <a href="/" class="text-lg font-bold tracking-tight no-underline">LOVE LEARN LIFT</a>
        <nav class="text-sm font-mono uppercase tracking-wider text-neutral-400">
          <ul class="flex flex-wrap gap-x-6 gap-y-1">
            <li><a class="hover:text-white" href="/">Home</a></li>
            {categoryList.map((c) => (
              <li><a class="hover:text-white" href={`/${c.slug}`}>{c.name}</a></li>
            ))}
            <li><a class="text-gold hover:text-white" href="/encode/learn">Learn</a></li>
          </ul>
        </nav>
      </div>
    </header>

    <!-- Hero — black, full-width, dramatic -->
    <section class="border-b border-neutral-800">
      <div class="max-w-6xl mx-auto px-6 py-20 md:py-28">
        <p class="text-xs md:text-sm font-mono uppercase tracking-[0.3em] text-flame mb-6">// 24-month public build program</p>
        <h1 class="text-6xl md:text-8xl font-black tracking-tight leading-[0.95] mb-6">
          Learn.<br/>
          Build.<br/>
          Launch.
        </h1>
        <p class="text-lg md:text-xl text-neutral-300 max-w-2xl leading-relaxed">
          Two pillars. Forge ships the code. Encode locks the lessons. The calendar below is the audit — a day counts when at least one post ships.
        </p>
      </div>
    </section>

    <!-- Daily completion calendar — neutral-900 band -->
    <Calendar />

    <!-- Masterclass CTA — gold band, marketable, high on the page (repointed from Homework E33) -->
    <section class="border-b border-neutral-800 bg-gold text-black">
      <div class="max-w-6xl mx-auto px-6 py-12 md:py-16 flex flex-col md:flex-row md:items-center md:justify-between gap-8">
        <div class="max-w-2xl">
          <p class="text-xs font-mono uppercase tracking-[0.3em] mb-3">// New — The masterclass</p>
          <h2 class="text-3xl md:text-5xl font-black tracking-tight mb-4 leading-[0.95]">Don't just read it.<br/>Lock it in.</h2>
          <p class="text-base md:text-lg leading-relaxed">
            Work the Claude 101 masterclass — every module with a question before every answer, a self-scoring
            quiz, and a clear path from Module 1 to the final. Free, no signup, your progress stays in your browser.
          </p>
        </div>
        <a href="/encode/learn" class="shrink-0 inline-flex items-center gap-2 bg-black text-gold font-mono uppercase tracking-wider text-sm px-7 py-4 no-underline hover:bg-neutral-900 transition-colors">
          Start the masterclass →
        </a>
      </div>
    </section>

    <!-- The Split — Encode (I) | Forge (II). -->
    <section class="grid grid-cols-1 md:grid-cols-2 border-b border-neutral-800">
      <!-- ENCODE — black — Pillar I — all white text -->
      <div class="bg-black text-white border-b md:border-b-0 md:border-r border-neutral-800">
        <div class="px-6 md:px-8 py-16 md:py-20">
          <p class="text-xs font-mono uppercase tracking-[0.3em] text-white mb-4">// Pillar I — Learn</p>
          <h2 class="text-4xl md:text-5xl font-black tracking-tight mb-4">ENCODE</h2>
          <p class="text-base text-white mb-10 leading-relaxed">Learning in public. Sit down at zero, leave with one thing locked. The misses are part of the data.</p>

          <div class="space-y-5 mb-10">
            {encodePosts.length === 0 ? (
              <p class="text-white">No Encode posts yet.</p>
            ) : encodePosts.map((post) => (
              <article class="border-b border-neutral-800 pb-5 last:border-b-0">
                <p class="text-xs font-mono uppercase tracking-wider text-white mb-2">
                  {post.data.date.toISOString().slice(0, 10)}
                </p>
                <h3 class="text-lg font-bold mb-1 tracking-tight leading-snug">
                  <a href={`/blog/${post.slug}`} class="no-underline hover:underline">{post.data.title}</a>
                </h3>
                <p class="text-white text-sm leading-relaxed">{post.data.excerpt}</p>
              </article>
            ))}
          </div>

          <a href="/encode" class="inline-flex items-center gap-2 text-sm font-mono uppercase tracking-wider text-white hover:text-white no-underline border-b border-white/40 hover:border-white pb-1">
            All Encode →
          </a>
        </div>
      </div>

      <!-- FORGE — red — Pillar II (now the last column) -->
      <div class="bg-flame text-gold">
        <div class="px-6 md:px-8 py-16 md:py-20">
          <p class="text-xs font-mono uppercase tracking-[0.3em] text-gold/80 mb-4">// Pillar II — Build</p>
          <h2 class="text-4xl md:text-5xl font-black tracking-tight mb-4">FORGE</h2>
          <p class="text-base text-gold/80 mb-10 leading-relaxed">Building and shipping. Code lands in production. The trade-offs that earned it. The rules I write so I don't make the same mistake twice.</p>

          <div class="space-y-8 mb-10">
            {forgeBuilds.map((b) => (
              <div>
                <div class="flex items-baseline justify-between mb-3 pb-2 border-b border-black/20">
                  <p class="text-sm font-mono uppercase tracking-[0.2em] text-gold font-bold">{b.name}</p>
                  <p class="text-[10px] font-mono uppercase tracking-wider text-gold/60">{b.order} · {b.stage}</p>
                </div>
                <div class="space-y-4 mb-4">
                  {b.posts.length === 0 ? (
                    <p class="text-gold/70 text-sm">No sessions yet.</p>
                  ) : b.posts.map((post) => (
                    <article>
                      <p class="text-xs font-mono uppercase tracking-wider text-gold/70 mb-1">
                        {post.data.date.toISOString().slice(0, 10)}
                      </p>
                      <h3 class="text-base font-bold tracking-tight leading-snug">
                        <a href={`/blog/${post.slug}`} class="no-underline hover:underline">{post.data.title}</a>
                      </h3>
                    </article>
                  ))}
                </div>
                <a href={b.href} class="inline-flex items-center gap-2 text-xs font-mono uppercase tracking-wider text-gold hover:text-white no-underline border-b border-gold/40 hover:border-gold pb-1">
                  All {b.name} →
                </a>
              </div>
            ))}
          </div>
        </div>
      </div>

    </section>
    {/* Pillar III block archived E32 2026-06-27 — removed from homepage; route + posts kept on disk. */}

    <!-- Currently studying — external coursework, listed honestly -->
    <section class="border-t border-neutral-800 bg-black">
      <div class="max-w-6xl mx-auto px-6 py-10">
        <p class="text-xs font-mono uppercase tracking-[0.3em] text-flame mb-4">// Currently studying</p>
        <p class="text-base md:text-lg text-neutral-300 leading-relaxed max-w-3xl">
          <a href="https://anthropic.skilljar.com/claude-101" rel="noopener noreferrer" target="_blank" class="text-white hover:underline">Claude 101 — Anthropic Academy</a>
          <span class="text-neutral-500"> — learning the tool I build with, straight from the source: what Claude is, how to prompt it, how to put it to work. Ground-zero up, one module a day, each one turned into a quiz here. <span class="text-neutral-600">· free · data-analytics paused</span></span>
        </p>
      </div>
    </section>

    <!-- Footer — black, full-width -->
    <footer class="bg-black border-t border-neutral-800">
      <div class="max-w-6xl mx-auto px-6 py-8 flex items-center justify-between text-sm font-mono text-neutral-500">
        <span>&copy; {year} Love Learn Lift</span>
        <a class="hover:text-white" href="https://github.com/tortoisehq" rel="noopener noreferrer">GitHub</a>
      </div>
    </footer>
  </body>
</html>
