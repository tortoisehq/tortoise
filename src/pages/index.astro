---
import '../styles/global.css';
import { getCollection } from 'astro:content';
import Calendar from '../components/Calendar.astro';
import { categoryList } from '../lib/categories';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const forgePosts = posts.filter((p) => p.data.category === 'forge').slice(0, 4);
const encodePosts = posts.filter((p) => p.data.category === 'encode').slice(0, 4);

const year = new Date().getFullYear();
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="A 24-month public build program. Forge: building and shipping. Encode: learning in public." />
    <title>Tortoise</title>
  </head>
  <body class="min-h-screen bg-black text-white antialiased">
    <!-- Header — full-width black -->
    <header class="border-b border-neutral-800">
      <div class="max-w-6xl mx-auto px-6 py-5 flex items-center justify-between">
        <a href="/" class="text-lg font-bold tracking-tight no-underline">TORTOISE</a>
        <nav class="text-sm font-mono uppercase tracking-wider text-neutral-400">
          <ul class="flex flex-wrap gap-x-6 gap-y-1">
            <li><a class="hover:text-white" href="/">Home</a></li>
            {categoryList.map((c) => (
              <li><a class="hover:text-white" href={`/${c.slug}`}>{c.name}</a></li>
            ))}
            <li><a class="hover:text-white" href="/findings">Findings</a></li>
            <li><a class="hover:text-white" href="/resume">Resume</a></li>
          </ul>
        </nav>
      </div>
    </header>

    <!-- Hero — black, full-width, dramatic -->
    <section class="border-b border-neutral-800">
      <div class="max-w-6xl mx-auto px-6 py-20 md:py-28">
        <p class="text-xs md:text-sm font-mono uppercase tracking-[0.3em] text-neutral-500 mb-6">// 24-month public build program</p>
        <h1 class="text-6xl md:text-8xl font-black tracking-tight leading-[0.95] mb-6">
          Build.<br/>
          <span class="text-neutral-500">Then learn.</span><br/>
          <span class="text-neutral-700">Then build again.</span>
        </h1>
        <p class="text-lg md:text-xl text-neutral-300 max-w-2xl leading-relaxed">
          Two pillars. Every day, both. Forge ships code. Encode locks the lessons. The calendar below is the audit — a day only counts when both are done.
        </p>
      </div>
    </section>

    <!-- Daily completion calendar — neutral-900 band -->
    <Calendar />

    <!-- The Split — Encode (Pillar I) | Forge (Pillar II) -->
    <section class="grid grid-cols-1 md:grid-cols-2 border-b border-neutral-800">
      <!-- ENCODE side — white — Pillar I -->
      <div class="bg-white text-black border-b md:border-b-0 md:border-r border-neutral-800">
        <div class="px-6 md:px-10 py-16 md:py-20 max-w-2xl md:ml-auto md:w-full">
          <p class="text-xs font-mono uppercase tracking-[0.3em] text-neutral-500 mb-4">// Pillar I — Learn</p>
          <h2 class="text-5xl md:text-6xl font-black tracking-tight mb-4">ENCODE</h2>
          <p class="text-lg text-neutral-700 mb-10 leading-relaxed">Learning in public. Sessions where I sit down at zero and try to leave with one thing locked. The misses are part of the data.</p>

          <div class="space-y-5 mb-10">
            {encodePosts.length === 0 ? (
              <p class="text-neutral-500">No Encode posts yet.</p>
            ) : encodePosts.map((post) => (
              <article class="border-b border-neutral-200 pb-5 last:border-b-0">
                <p class="text-xs font-mono uppercase tracking-wider text-neutral-500 mb-2">
                  {post.data.date.toISOString().slice(0, 10)}
                </p>
                <h3 class="text-xl font-bold mb-1 tracking-tight leading-snug">
                  <a href={`/blog/${post.slug}`} class="no-underline hover:underline">{post.data.title}</a>
                </h3>
                <p class="text-neutral-700 text-sm leading-relaxed">{post.data.excerpt}</p>
              </article>
            ))}
          </div>

          <a href="/encode" class="inline-flex items-center gap-2 text-sm font-mono uppercase tracking-wider text-neutral-700 hover:text-black no-underline border-b border-neutral-300 hover:border-black pb-1">
            All Encode sessions →
          </a>
        </div>
      </div>

      <!-- FORGE side — black — Pillar II -->
      <div class="bg-black text-white">
        <div class="px-6 md:px-10 py-16 md:py-20 max-w-2xl md:mr-auto md:w-full">
          <p class="text-xs font-mono uppercase tracking-[0.3em] text-neutral-500 mb-4">// Pillar II — Build</p>
          <h2 class="text-5xl md:text-6xl font-black tracking-tight mb-4">FORGE</h2>
          <p class="text-lg text-neutral-300 mb-10 leading-relaxed">Building and shipping. Sessions where code lands in production. The trade-offs that earned it. The rules I write so I don't make the same mistake twice.</p>

          <div class="space-y-5 mb-10">
            {forgePosts.length === 0 ? (
              <p class="text-neutral-500">No Forge posts yet.</p>
            ) : forgePosts.map((post) => (
              <article class="border-b border-neutral-900 pb-5 last:border-b-0">
                <p class="text-xs font-mono uppercase tracking-wider text-neutral-500 mb-2">
                  {post.data.date.toISOString().slice(0, 10)}
                </p>
                <h3 class="text-xl font-bold mb-1 tracking-tight leading-snug">
                  <a href={`/blog/${post.slug}`} class="no-underline hover:underline">{post.data.title}</a>
                </h3>
                <p class="text-neutral-400 text-sm leading-relaxed">{post.data.excerpt}</p>
              </article>
            ))}
          </div>

          <a href="/forge" class="inline-flex items-center gap-2 text-sm font-mono uppercase tracking-wider text-neutral-300 hover:text-white no-underline border-b border-neutral-700 hover:border-white pb-1">
            All Forge sessions →
          </a>
        </div>
      </div>
    </section>

    <!-- Footer — black, full-width -->
    <footer class="bg-black border-t border-neutral-800">
      <div class="max-w-6xl mx-auto px-6 py-8 flex items-center justify-between text-sm font-mono text-neutral-500">
        <span>&copy; {year} Tortoise</span>
        <a class="hover:text-white" href="https://github.com/tortoisehq" rel="noopener noreferrer">GitHub</a>
      </div>
    </footer>
  </body>
</html>
