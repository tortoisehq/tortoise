---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import PostListItem from '../components/PostListItem.astro';
import { categoryList } from '../lib/categories';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const recent = posts.slice(0, 3);
---

<Layout>
  <section class="mb-16">
    <h1 class="text-5xl font-bold tracking-tight mb-3">Tortoise</h1>
    <p class="text-xl text-neutral-300">A 24-month public build program.</p>
  </section>

  <section class="mb-16">
    <h2 class="text-sm font-sans uppercase tracking-wider text-neutral-400 mb-4">Categories</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      {categoryList.map((c) => (
        <a
          href={`/blog/${c.slug}`}
          class="block p-5 border border-neutral-800 rounded-lg no-underline hover:border-neutral-500"
        >
          <div class="font-sans font-semibold text-lg">{c.name}</div>
          <div class="text-neutral-300 text-sm mt-1">{c.description}</div>
        </a>
      ))}
    </div>
  </section>

  <section class="mb-16">
    <h2 class="text-sm font-sans uppercase tracking-wider text-neutral-400 mb-4">Current Build</h2>
    <a
      href="/blog/forge"
      class="block p-5 border border-neutral-800 rounded-lg no-underline hover:border-neutral-500"
    >
      <div class="font-sans font-semibold text-lg">Workhorse</div>
      <div class="text-neutral-300 text-sm mt-1">A personal agent that automates Forge, Encode, and Endure — piece by piece over 24 months.</div>
    </a>
  </section>

  <section>
    <h2 class="text-sm font-sans uppercase tracking-wider text-neutral-400 mb-2">Recent posts</h2>
    {recent.length === 0 ? (
      <p class="text-neutral-400">No posts yet.</p>
    ) : (
      <div>
        {recent.map((post) => <PostListItem post={post} />)}
      </div>
    )}
  </section>
</Layout>
