---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import PostListItem from '../../components/PostListItem.astro';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<Layout title="Blog" description="All posts from Tortoise.">
  <header class="mb-10">
    <h1 class="text-4xl font-bold tracking-tight mb-2">Blog</h1>
    <p class="text-neutral-300">Everything, newest first.</p>
  </header>

  {posts.length === 0 ? (
    <p class="text-neutral-400">No posts yet.</p>
  ) : (
    <div>
      {posts.map((post) => <PostListItem post={post} />)}
    </div>
  )}
</Layout>
