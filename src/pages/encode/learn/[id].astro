---
import Layout from '../../../layouts/Layout.astro';
import Quiz from '../../../components/Quiz.astro';
import homework from '../../../data/homework.json';

export async function getStaticPaths() {
  const mods = import.meta.glob('../../../data/learn/*.json', { eager: true });
  const all = Object.values(mods).map((m: any) => m.default ?? m);
  return all.map((data: any) => {
    // siblings in the same course, ordered by module number → prev/next + position
    const siblings = all
      .filter((x: any) => (x.courseId ?? 'misc') === (data.courseId ?? 'misc'))
      .sort((a: any, b: any) => (a.module ?? 99) - (b.module ?? 99));
    const i = siblings.findIndex((x: any) => x.id === data.id);
    const lite = (x: any) => x ? { id: x.id, title: x.title, module: x.module } : null;
    return {
      params: { id: data.id },
      props: {
        data,
        position: { index: i, total: siblings.length },
        prev: lite(siblings[i - 1]),
        next: lite(siblings[i + 1]),
      },
    };
  });
}

const { data, position, prev, next } = Astro.props as { data: any; position: any; prev: any; next: any };
const quiz = (homework as any[]).find((q) => q.id === data.quizId);
const passPct = quiz?.passPct ?? 80;
---

<Layout title={`${data.title} — Learn`} description={data.promise} palette="encode">
  <!-- breadcrumb -->
  <header class="mb-8">
    <p class="text-xs font-mono uppercase tracking-[0.25em] text-stone-500 mb-3">
      <a href="/encode" class="hover:text-white">// Encode</a> /
      <a href="/encode/learn" class="hover:text-white">Learn</a> / {data.title}
    </p>
    <div class="flex items-baseline gap-3 mb-4 flex-wrap">
      {data.module ? <span class="text-[10px] font-mono uppercase tracking-[0.2em] text-amber-500 border border-amber-500/40 px-2 py-0.5">Module {data.module} of {position?.total ?? data.module}</span> : null}
      <span class="text-sm font-mono text-stone-500">{data.course}</span>
    </div>
    <h1 class="text-4xl font-bold tracking-tight mb-3">{data.title}</h1>
    <p class="text-lg text-stone-300 max-w-2xl leading-relaxed">{data.promise}</p>
  </header>

  <!-- framework spine: the loop -->
  <section class="mb-8 border border-stone-700 bg-stone-900">
    <p class="px-5 pt-4 text-[10px] font-mono uppercase tracking-[0.2em] text-stone-500">// How every module here works</p>
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-px bg-stone-800 border-t border-stone-800 mt-3">
      {data.loop.map((l: any, i: number) => (
        <div class="bg-stone-900 p-4">
          <p class="text-sm font-bold tracking-tight">{i + 1}. {l.step}</p>
          <p class="text-xs text-stone-400 mt-1 leading-relaxed">{l.blurb}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- the map -->
  <section class="mb-12">
    <p class="text-[10px] font-mono uppercase tracking-[0.2em] text-stone-500 mb-3">// The {data.title} map</p>
    <ol class="space-y-2">
      {data.map.map((stop: any, i: number) => (
        <li class="flex gap-3 border-l-2 border-stone-700 pl-4 py-1">
          <span class="font-mono text-xs text-stone-500 mt-0.5">{i + 1}</span>
          <span><span class="font-semibold text-white">{stop.stop}</span><span class="text-stone-400"> — {stop.blurb}</span></span>
        </li>
      ))}
    </ol>
  </section>

  <!-- intro -->
  <section class="mb-12 space-y-4 text-stone-200 leading-relaxed">
    {data.intro.map((p: string) => <p>{p}</p>)}
  </section>

  <!-- study sections -->
  <section class="mb-14">
    <h2 class="text-2xl font-bold tracking-tight mb-6 border-b border-stone-700 pb-2">Study — {data.sections.length} objectives, one at a time</h2>
    <div class="space-y-8">
      {data.sections.map((s: any) => (
        <article class="border-l-2 border-stone-800 pl-5">
          <div class="flex items-baseline gap-3 mb-2">
            <span class="text-[10px] font-mono uppercase tracking-[0.15em] text-stone-500 border border-stone-700 px-1.5 py-0.5">{s.lesson} · {s.n}</span>
            <h3 class="text-xl font-bold tracking-tight">{s.heading}</h3>
          </div>
          <p class="text-stone-300 mb-3"><span class="text-[10px] font-mono uppercase tracking-[0.15em] text-amber-600 mr-2">Try first</span>{s.challenge}</p>
          <details class="group mb-2">
            <summary class="cursor-pointer text-sm font-mono text-stone-400 hover:text-white">Show the idea →</summary>
            <div class="mt-3 space-y-3 text-stone-200 leading-relaxed">
              {s.body.map((p: string) => <p>{p}</p>)}
              <p class="text-stone-400 border-l-2 border-stone-700 pl-3 italic">In plain terms: {s.plain}</p>
            </div>
          </details>
          <details class="group">
            <summary class="cursor-pointer text-sm font-mono text-stone-400 hover:text-white">Lock it — can you say this back? →</summary>
            <p class="mt-3 text-stone-200 leading-relaxed border-l-2 border-green-700 pl-3">{s.lockIt}</p>
          </details>
        </article>
      ))}
    </div>
  </section>

  <!-- golden nugget -->
  <section class="mb-14">
    <h2 class="text-2xl font-bold tracking-tight mb-2 border-b border-stone-700 pb-2">The golden nugget</h2>
    <article class="mt-5 border border-amber-900/50 bg-stone-900 p-5">
      <h3 class="text-xl font-bold tracking-tight mb-2">{data.nugget.title}</h3>
      <p class="text-stone-300 mb-3"><span class="text-[10px] font-mono uppercase tracking-[0.15em] text-amber-600 mr-2">Try first</span>{data.nugget.challenge}</p>
      <details class="group mb-2">
        <summary class="cursor-pointer text-sm font-mono text-stone-400 hover:text-white">Show the idea →</summary>
        <div class="mt-3 space-y-3 text-stone-200 leading-relaxed">
          {data.nugget.body.map((p: string) => <p>{p}</p>)}
          <p class="text-stone-400 border-l-2 border-stone-700 pl-3">{data.nugget.whyItMatters}</p>
        </div>
      </details>
      <details class="group">
        <summary class="cursor-pointer text-sm font-mono text-stone-400 hover:text-white">Lock it — can you say this back? →</summary>
        <p class="mt-3 text-stone-200 leading-relaxed border-l-2 border-green-700 pl-3">{data.nugget.lockIt}</p>
      </details>
    </article>
  </section>

  <!-- prove: the quiz -->
  <section class="mb-10">
    <h2 class="text-2xl font-bold tracking-tight mb-2 border-b border-stone-700 pb-2">Prove it</h2>
    <p class="text-stone-300 text-sm leading-relaxed mb-5 mt-3">
      Reading is not knowing. Pick a difficulty and take the quiz — <strong>Easy</strong> recognizes, <strong>Medium</strong> is the full mix, <strong>Hard</strong> makes you type every answer from memory. Missed questions and trap-spots come back first.
    </p>
    {quiz ? <Quiz quiz={quiz} /> : <p class="text-stone-500 text-sm">Quiz coming soon.</p>}
  </section>

  <!-- progress strip -->
  <section id="hub-progress" class="mb-10 hidden border border-stone-700 bg-stone-900 p-5">
    <p class="text-[10px] font-mono uppercase tracking-[0.2em] text-stone-500 mb-3">// Your progress (saved in this browser)</p>
    <div class="grid grid-cols-3 gap-px bg-stone-800 border border-stone-800 text-center">
      <div class="bg-stone-900 py-3"><div id="hp-best" class="text-xl font-bold tabular-nums">—</div><div class="text-[10px] font-mono uppercase tracking-[0.15em] text-stone-500">Best</div></div>
      <div class="bg-stone-900 py-3"><div id="hp-streak" class="text-xl font-bold tabular-nums">—</div><div class="text-[10px] font-mono uppercase tracking-[0.15em] text-stone-500">Streak</div></div>
      <div class="bg-stone-900 py-3"><div id="hp-attempts" class="text-xl font-bold tabular-nums">—</div><div class="text-[10px] font-mono uppercase tracking-[0.15em] text-stone-500">Attempts</div></div>
    </div>
    <p id="hp-badge" class="mt-3 text-sm font-mono"></p>
  </section>

  <!-- outro -->
  <section class="mb-10 space-y-4 text-stone-200 leading-relaxed border-t border-stone-800 pt-8">
    {data.outro.map((p: string) => <p>{p}</p>)}
  </section>

  <!-- prev / next module nav -->
  <nav class="mt-10 grid grid-cols-2 gap-px bg-stone-800 border border-stone-800 text-sm">
    <div class="bg-stone-900">
      {prev ? (
        <a href={`/encode/learn/${prev.id}`} class="block p-4 hover:bg-stone-900/60 transition-colors group">
          <span class="text-[10px] font-mono uppercase tracking-[0.2em] text-stone-500">← Module {prev.module}</span>
          <span class="block font-semibold tracking-tight group-hover:underline mt-1">{prev.title}</span>
        </a>
      ) : (
        <a href="/encode/learn" class="block p-4 hover:bg-stone-900/60 transition-colors">
          <span class="text-[10px] font-mono uppercase tracking-[0.2em] text-stone-500">←</span>
          <span class="block font-semibold tracking-tight mt-1">All modules</span>
        </a>
      )}
    </div>
    <div class="bg-stone-900 text-right">
      {next ? (
        <a href={`/encode/learn/${next.id}`} class="block p-4 hover:bg-stone-900/60 transition-colors group">
          <span class="text-[10px] font-mono uppercase tracking-[0.2em] text-amber-500">Module {next.module} →</span>
          <span class="block font-semibold tracking-tight group-hover:underline mt-1">{next.title}</span>
        </a>
      ) : (
        <a href="/encode/learn" class="block p-4 hover:bg-stone-900/60 transition-colors">
          <span class="text-[10px] font-mono uppercase tracking-[0.2em] text-stone-500">→</span>
          <span class="block font-semibold tracking-tight mt-1">Back to all modules</span>
        </a>
      )}
    </div>
  </nav>
</Layout>

<script define:vars={{ quizId: data.quizId, total: quiz?.questions?.length ?? 0, passPct }}>
  try {
    const raw = localStorage.getItem(`lll-hw-${quizId}`);
    if (raw) {
      const s = JSON.parse(raw);
      if (s && s.attempts) {
        document.getElementById('hub-progress').classList.remove('hidden');
        document.getElementById('hp-best').textContent = `${s.bestScore ?? 0}/${total}`;
        document.getElementById('hp-streak').textContent = String(s.streak ?? 0);
        document.getElementById('hp-attempts').textContent = String(s.attempts ?? 0);
        const badge = document.getElementById('hp-badge');
        if ((s.bestPct ?? 0) >= 100) { badge.textContent = '🔒 Module sealed — 100%'; badge.className = 'mt-3 text-sm font-mono text-green-600'; }
        else if ((s.bestPct ?? 0) >= passPct) { badge.textContent = '✓ Module locked — keep returning to seal it'; badge.className = 'mt-3 text-sm font-mono text-green-700'; }
        else { badge.textContent = 'In progress — get to ' + passPct + '% to lock it'; badge.className = 'mt-3 text-sm font-mono text-amber-600'; }
      }
    }
  } catch {}
</script>
