---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import PostListItem from '../../components/PostListItem.astro';
import { categories } from '../../lib/categories';
// ARCHIVED S61 — Method + Definitions apparatus pulled from the live page (data files kept on disk).
// import definitions from '../../data/definitions.json';
// import methodVersions from '../../data/method-versions.json';

const meta = categories.encode;

const posts = (await getCollection('blog', ({ data }) => !data.draft && data.category === 'encode'))
  .sort((a, b) => (b.data.date.getTime() - a.data.date.getTime()) || b.slug.localeCompare(a.slug, undefined, { numeric: true }));

// ARCHIVED S61 — restore alongside the Method/Definitions blocks below to bring them back.
// type Definition = { term: string; category: string; definition: string; session: string };
// const defsByCat = (definitions as Definition[]).reduce((acc, def) => {
//   (acc[def.category] = acc[def.category] || []).push(def);
//   return acc;
// }, {} as Record<string, Definition[]>);
// const categoryOrder = ['data-analytics', 'python', 'memory', 'learning'];
// const orderedCategories = categoryOrder.filter((c) => defsByCat[c]);
// type MethodVersion = { version: string; codifiedAt: string; codifiedSession: string; nextEvolutionAt: string; summary: string };
// const sortedMethod = (methodVersions as MethodVersion[]).slice()
//   .sort((a, b) => b.codifiedAt.localeCompare(a.codifiedAt));
// const currentMethod = sortedMethod[0];
---

<Layout title={meta.name} description={meta.description} palette="encode">
  <header class="mb-12">
    <p class="text-xs font-mono uppercase tracking-[0.25em] text-neutral-500 mb-3">// Pillar I — Learn</p>
    <h1 class="text-5xl font-bold tracking-tight mb-3">Encode</h1>
    <p class="text-lg text-neutral-300 max-w-xl">Learning in public. Sessions where I sit down at zero and try to leave with one thing locked. The misses are part of the data.</p>
  </header>

  <a href="/encode/learn" class="block mb-4 border border-neutral-700 p-5 hover:bg-neutral-900 transition-colors group">
    <div class="flex items-center justify-between gap-4">
      <div>
        <p class="text-[10px] font-mono uppercase tracking-[0.2em] text-neutral-500 mb-1">Learn</p>
        <p class="text-white font-semibold">Masterclass study guides — study, prove, return →</p>
        <p class="text-sm text-neutral-400 mt-1">One page per module: a challenge before every answer, a self-scoring quiz at three difficulties, and your mastery saved as you go. Start with Meet Claude.</p>
      </div>
      <span class="text-neutral-500 text-lg font-mono group-hover:translate-x-1 transition-transform">→</span>
    </div>
  </a>

  {/* ARCHIVED S61 — Homework/Quiz CTA pulled from the live page (page still lives at /encode/homework).
  <a href="/encode/homework" class="block mb-4 border border-black p-5 hover:bg-neutral-50 transition-colors group">
    <div class="flex items-center justify-between gap-4">
      <div>
        <p class="text-[10px] font-mono uppercase tracking-[0.2em] text-neutral-500 mb-1">Homework</p>
        <p class="text-black font-semibold">Quiz yourself on what I've locked →</p>
        <p class="text-sm text-neutral-600 mt-1">Scoreable retrieval practice. Instant feedback, streaks, missed-questions-come-back-first.</p>
      </div>
      <span class="text-neutral-400 text-lg font-mono group-hover:translate-x-1 transition-transform">→</span>
    </div>
  </a>
  */}

  {/* ARCHIVED S61 — Method apparatus block (data kept in method-versions.json; page still at /encode/method).
  <details class="mb-4 border border-neutral-200 group">
    <summary class="cursor-pointer p-4 flex items-center justify-between hover:bg-neutral-50" style="list-style:none;">
      <span class="flex flex-col sm:flex-row sm:items-baseline sm:gap-2">
        <span class="text-[10px] font-mono uppercase tracking-[0.2em] text-neutral-500">Method</span>
        <span class="text-black font-semibold">v{currentMethod.version} — 60-min sessions, 4 templates, evolves at {currentMethod.nextEvolutionAt}</span>
      </span>
      <span class="text-neutral-400 text-xs font-mono ml-3 group-open:rotate-90 transition-transform">▶</span>
    </summary>
    <div class="px-4 pb-5 pt-3 border-t border-neutral-200 bg-neutral-50 space-y-3 text-sm">
      <p class="text-neutral-700 leading-relaxed">{currentMethod.summary}</p>
      <p class="text-xs font-mono text-neutral-500">
        Codified {currentMethod.codifiedAt} · session {currentMethod.codifiedSession} · next evolution at <span class="text-black font-semibold">{currentMethod.nextEvolutionAt}</span>
      </p>
      <p class="pt-2 text-xs font-mono">
        <a href="/encode/method" class="underline hover:text-black">Read the full method →</a>
      </p>
    </div>
  </details>
  */}

  <details class="mb-12 border border-neutral-800 group">
    <summary class="cursor-pointer p-4 flex items-center justify-between hover:bg-neutral-900" style="list-style:none;">
      <span class="flex flex-col sm:flex-row sm:items-baseline sm:gap-2">
        <span class="text-[10px] font-mono uppercase tracking-[0.2em] text-neutral-500">Currently studying</span>
        <span class="text-white font-semibold">Claude 101 — Anthropic Academy</span>
      </span>
      <span class="text-neutral-400 text-xs font-mono ml-3 group-open:rotate-90 transition-transform">▶</span>
    </summary>
    <div class="px-4 pb-5 pt-3 border-t border-neutral-800 bg-neutral-900 space-y-3 text-sm">
      <p class="text-neutral-300 leading-relaxed">
        Learning the tool I build with every day, straight from the source: what Claude is, how to talk to it, the three desktop modes, and the moves that make it actually useful. Ground-zero up, one module per session, each module turned into a quiz on this site. Google Data Analytics is paused for now.
      </p>
      <p class="pt-2 text-xs font-mono">
        <a href="https://anthropic.skilljar.com/claude-101" rel="noopener noreferrer" target="_blank" class="underline hover:text-white">Claude 101 on Anthropic Academy ↗ <span class="text-neutral-400">(free)</span></a>
      </p>
    </div>
  </details>

  {/* ARCHIVED S61 — Definitions apparatus block (the 47 terms incl. the "memory" category; data kept in definitions.json).
  <details class="mb-12 border border-neutral-200 group">
    <summary class="cursor-pointer p-4 flex items-center justify-between hover:bg-neutral-50" style="list-style:none;">
      <span class="flex flex-col sm:flex-row sm:items-baseline sm:gap-2">
        <span class="text-[10px] font-mono uppercase tracking-[0.2em] text-neutral-500">Definitions</span>
        <span class="text-black font-semibold">{(definitions as Definition[]).length} terms locked</span>
      </span>
      <span class="text-neutral-400 text-xs font-mono ml-3 group-open:rotate-90 transition-transform">▶</span>
    </summary>
    <div class="px-4 pb-5 pt-3 border-t border-neutral-200 bg-neutral-50 space-y-6">
      {orderedCategories.map((cat) => (
        <div>
          <p class="text-[10px] font-mono uppercase tracking-[0.2em] text-neutral-500 mb-3 mt-2">{cat}</p>
          <dl class="space-y-3">
            {defsByCat[cat].map((def) => (
              <div>
                <dt class="text-black font-semibold text-sm">{def.term} <span class="text-neutral-400 font-mono text-[10px] font-normal">{def.session}</span></dt>
                <dd class="text-neutral-700 text-sm leading-relaxed">{def.definition}</dd>
              </div>
            ))}
          </dl>
        </div>
      ))}
    </div>
  </details>
  */}

  {posts.length === 0 ? (
    <p class="text-neutral-400">No posts in this category yet.</p>
  ) : (
    <div>
      {posts.map((post) => <PostListItem post={post} palette="encode" />)}
    </div>
  )}
</Layout>

<style>
  details > summary::-webkit-details-marker { display: none; }
  details > summary { list-style: none; }
</style>
